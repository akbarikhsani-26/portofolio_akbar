---

---

<!-- Contact Section -->
<section class="min-h-screen flex flex-col justify-center py-20" id="solutions">
    <div
        class="max-w-3xl mx-auto bg-surface-container-lowest border border-outline rounded-none shadow-[0_10px_30px_rgba(0,0,0,0.5)]"
    >
        <!-- CLI Header -->
        <div
            class="bg-surface-container px-4 py-2 flex items-center gap-2 border-b border-outline"
        >
            <div class="w-3 h-3 rounded-full bg-error"></div>
            <div class="w-3 h-3 rounded-full bg-tertiary-fixed"></div>
            <div class="w-3 h-3 rounded-full bg-primary"></div>
            <span
                class="font-label-mono text-label-mono text-on-surface-variant ml-4"
                >terminal - akbar@portfolio:~</span
            >
        </div>
        <!-- CLI Body -->
        <div
            class="p-6 font-label-mono text-[14px] text-on-surface-variant space-y-6 bg-surface-container-lowest"
        >
            <div class="text-primary">
                akbar@portfolio:~$ <span class="text-secondary"
                    >list --connections</span
                >
            </div>

            <div class="grid gap-4 pl-4 border-l border-outline-variant/50">
                <!-- LinkedIn -->
                <a
                    href="https://www.linkedin.com/in/nurvianto-akbar-ikhsani"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-4 p-4 border border-outline hover:border-primary hover:bg-primary/5 transition-all duration-300 decoration-none"
                >
                    <span
                        class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform"
                        data-icon="share">share</span
                    >
                    <div class="flex flex-col">
                        <span class="text-primary font-bold">LINKEDIN.EXE</span>
                        <span
                            class="text-[10px] text-on-surface-variant/70 uppercase tracking-tighter"
                            >Professional_Network_Protocol</span
                        >
                    </div>
                    <span
                        class="ml-auto material-symbols-outlined text-[16px] opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0"
                        data-icon="open_in_new">open_in_new</span
                    >
                </a>

                <!-- Instagram -->
                <a
                    href="https://www.instagram.com/akbarikhsani_"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-4 p-4 border border-outline hover:border-secondary hover:bg-secondary/5 transition-all duration-300 decoration-none"
                >
                    <span
                        class="material-symbols-outlined text-secondary group-hover:scale-110 transition-transform"
                        data-icon="photo_camera">photo_camera</span
                    >
                    <div class="flex flex-col">
                        <span class="text-secondary font-bold"
                            >INSTAGRAM.SH</span
                        >
                        <span
                            class="text-[10px] text-on-surface-variant/70 uppercase tracking-tighter"
                            >Visual_Identity_Stream</span
                        >
                    </div>
                    <span
                        class="ml-auto material-symbols-outlined text-[16px] opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0"
                        data-icon="open_in_new">open_in_new</span
                    >
                </a>

                <!-- Email -->
                <a
                    href="mailto:akbarikhsani26@gmail.com"
                    class="group flex items-center gap-4 p-4 border border-outline hover:border-tertiary-fixed hover:bg-tertiary-fixed/5 transition-all duration-300 decoration-none"
                >
                    <span
                        class="material-symbols-outlined text-tertiary-fixed group-hover:scale-110 transition-transform"
                        data-icon="alternate_email">alternate_email</span
                    >
                    <div class="flex flex-col">
                        <span class="text-tertiary-fixed font-bold"
                            >EMAIL_CLIENT.BIN</span
                        >
                        <span
                            class="text-[10px] text-on-surface-variant/70 uppercase tracking-tighter"
                            >Direct_Access_Link</span
                        >
                    </div>
                    <span
                        class="ml-auto material-symbols-outlined text-[16px] opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0"
                        data-icon="mail">mail</span
                    >
                </a>
            </div>

            <div class="text-tertiary-fixed animate-pulse text-[12px]">
                &gt; Status: All communication channels ready. Select an
                endpoint to initiate connection...
            </div>
        </div>
    </div>
</section>

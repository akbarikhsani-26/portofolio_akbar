---
const experiences = [
  {
    type: "IT Staff and Support Internship • August 2024 - September 2024",
    title: "Dinas Pemberdayaan Perempuan, Perlindungan Anak, Pengendalian Penduduk, dan Keluarga Berencana Kota Batu • Divisi Puspaga",
    role: "Administration & Support",
    description: "Membantu dalam mengelola administrasi operasional sehingga mencapainya standarisasi Divisi Puspaga (Pusat Pembelajaran Keluarga). Pembuatan prototype website sistem informasi manajemen dan pelayanan Puspaga, dibuat untuk mempermudah dalam melakukan manajemen data dan penjadwalan kegiatan, serta mempermudah dalam pelayanan dan pencarian informasi.",
    image: "/media/project-2.png",
    color: "bg-primary",
    shadow: "shadow-[0_0_10px_rgba(79,70,229,0.8)]",
    borderColor: "hover:border-primary/50",
    borderLeft: "border-primary/30",
    link: "/projects/sim-puspaga"
  },
  {
    type: "Departmental Organization • November 2022 - December 2023",
    title: "Himpunan Mahasiswa Informatika",
    role: "Anggota Bidang Pengabdian Masyarakat",
    description: "Penyusunan program kerja yang selaras dengan tugas pokok dan fungsi (Tupoksi) serta mengelola komunikasi lintas elemen.",
    image: "/media/exp-teamwork.jpg",
    color: "bg-secondary",
    shadow: "shadow-[0_0_10px_rgba(6,182,212,0.8)]",
    borderColor: "hover:border-secondary/50",
    borderLeft: "border-secondary/30",
    link: "/projects/himpunan-mahasiswa"
  },
  {
    type: "Regional Organization • January 2023 - December 2023",
    title: "Permikomnas Wilayah IX Jatim",
    role: "Anggota Bidang Humas Dan Kominfo",
    description: "Mengelola strategi komunikasi di berbagai kanal media digital secara terintegrasi, Merancang konten visual yang inovatif, Membangun hubungan strategis dengan pihak eksternal dan media partner, Mendokumentasikan seluruh agenda kegiatan secara sistematis",
    image: "/media/exp-workflow.jpg",
    color: "bg-tertiary-fixed",
    shadow: "shadow-[0_0_10px_rgba(245,158,11,0.8)]",
    borderColor: "hover:border-tertiary-fixed/50",
    borderLeft: "border-tertiary-fixed/30"
  }
];
---

<!-- Experience Section -->
<section
  class="min-h-screen flex flex-col justify-center py-20 space-y-12"
  id="experience"
>
  <div class="flex items-center gap-4">
    <div class="h-px w-12 bg-secondary"></div>
    <h2
      class="font-label-mono text-label-mono text-secondary uppercase tracking-widest"
    >
      Experience
    </h2>
  </div>

  <div class="relative max-w-5xl mx-auto w-full">
    <!-- Vertical Timeline Line -->
    <div
      class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 w-px h-full bg-outline-variant/30"
    >
    </div>

    <div class="space-y-16">
      {experiences.map((exp, index) => (
        <div class="relative flex flex-col md:flex-row items-center">
          <!-- Timeline Dot -->
          <div
            class={`absolute -left-[5.5px] md:left-1/2 transform md:-translate-x-1/2 w-3 h-3 ${exp.color} rounded-none ${exp.shadow} z-10`}
          >
          </div>
          <!-- Empty side for timeline balance -->
          {index % 2 === 0 ? (
            <>
              <div class="w-full md:w-1/2 pr-0 md:pr-12 pl-8 md:pl-0">
                {exp.link ? (
                  <a href={exp.link} class="block group">
                    <div class="bg-surface-container-low border border-outline-variant group-hover:border-primary/50 transition-all duration-500 overflow-hidden">
                      <div class="relative h-48 overflow-hidden">
                        <img 
                          src={exp.image} 
                          alt={exp.title} 
                          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"></div>
                      </div>
                      
                      <div class="p-6 pt-4">
                        <span class="font-label-mono text-[10px] text-primary tracking-widest uppercase">
                          {exp.type}
                        </span>
                        <h3 class="font-headline-md text-xl text-on-surface mt-2 group-hover:text-primary transition-colors">
                          {exp.title}
                        </h3>
                        <p class="font-body-md text-on-surface-variant/70 text-sm mt-1 mb-4">
                          {exp.role}
                        </p>
                        <p class={`font-body-md text-on-surface-variant text-sm leading-relaxed border-l ${exp.borderLeft} pl-4`}>
                          {exp.description}
                        </p>
                      </div>
                    </div>
                  </a>
                ) : (
                  <div class="bg-surface-container-low border border-outline-variant hover:border-primary/50 transition-all duration-500 group overflow-hidden">
                    <div class="relative h-48 overflow-hidden">
                      <img 
                        src={exp.image} 
                        alt={exp.title} 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"></div>
                    </div>
                    
                    <div class="p-6 pt-4">
                      <span class="font-label-mono text-[10px] text-primary tracking-widest uppercase">
                        {exp.type}
                      </span>
                      <h3 class="font-headline-md text-xl text-on-surface mt-2">
                        {exp.title}
                      </h3>
                      <p class="font-body-md text-on-surface-variant/70 text-sm mt-1 mb-4">
                        {exp.role}
                      </p>
                      <p class={`font-body-md text-on-surface-variant text-sm leading-relaxed border-l ${exp.borderLeft} pl-4`}>
                        {exp.description}
                      </p>
                    </div>
                  </div>
                )}
              </div>
              <div class="hidden md:block w-1/2 pl-12"></div>
            </>
          ) : (
            <>
              <div class="hidden md:block w-1/2 pr-12"></div>
              <div class="w-full md:w-1/2 pl-8 md:pl-12">
                {exp.link ? (
                  <a href={exp.link} class="block group">
                    <div class="bg-surface-container-low border border-outline-variant group-hover:border-secondary/50 transition-all duration-500 overflow-hidden">
                      <div class="relative h-48 overflow-hidden">
                        <img 
                          src={exp.image} 
                          alt={exp.title} 
                          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"></div>
                      </div>

                      <div class="p-6 pt-4">
                        <span class="font-label-mono text-[10px] text-secondary tracking-widest uppercase">
                          {exp.type}
                        </span>
                        <h3 class="font-headline-md text-xl text-on-surface mt-2 group-hover:text-secondary transition-colors">
                          {exp.title}
                        </h3>
                        <p class="font-body-md text-on-surface-variant/70 text-sm mt-1 mb-4">
                          {exp.role}
                        </p>
                        <p class={`font-body-md text-on-surface-variant text-sm leading-relaxed border-l ${exp.borderLeft} pl-4`}>
                          {exp.description}
                        </p>
                      </div>
                    </div>
                  </a>
                ) : (
                  <div class="bg-surface-container-low border border-outline-variant hover:border-secondary/50 transition-all duration-500 group overflow-hidden">
                    <div class="relative h-48 overflow-hidden">
                      <img 
                        src={exp.image} 
                        alt={exp.title} 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"></div>
                    </div>

                    <div class="p-6 pt-4">
                      <span class="font-label-mono text-[10px] text-secondary tracking-widest uppercase">
                        {exp.type}
                      </span>
                      <h3 class="font-headline-md text-xl text-on-surface mt-2">
                        {exp.title}
                      </h3>
                      <p class="font-body-md text-on-surface-variant/70 text-sm mt-1 mb-4">
                        {exp.role}
                      </p>
                      <p class={`font-body-md text-on-surface-variant text-sm leading-relaxed border-l ${exp.borderLeft} pl-4`}>
                        {exp.description}
                      </p>
                    </div>
                  </div>
                )}
              </div>
            </>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

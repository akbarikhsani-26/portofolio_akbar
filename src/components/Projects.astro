---

---

<!-- Case Studies Section -->
<section
    class="min-h-screen flex flex-col justify-center py-20 space-y-12"
    id="systems"
>
    <div class="flex items-center gap-4 justify-end">
        <h2
            class="font-label-mono text-label-mono text-tertiary-fixed uppercase tracking-widest text-right"
        >
            Projects
        </h2>
        <div class="h-px w-12 bg-tertiary-fixed"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <a
            href="https://github.com/akbarikhsani-26/Optimasi-Hasil-DeepMelaNet-Menggunakan-Hair-Removal-dan-Contrast-Enhancement"
            target="_blank"
            rel="noopener noreferrer"
            class="group block relative bg-surface-container-low border border-outline-variant overflow-hidden hover:no-underline"
        >
            <div
                class="h-48 relative overflow-hidden bg-surface-container-highest"
            >
                <img
                    src="/media/project-1.png"
                    alt="Skin Cancer Classification"
                    class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-80 transition-all duration-700 group-hover:scale-110"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"
                >
                </div>
                <div
                    class="absolute inset-0 border-2 border-dashed border-error-container m-4 group-hover:opacity-0 transition-opacity duration-500 flex items-center justify-center"
                >
                    <span
                        class="font-label-mono text-error font-bold rotate-12 opacity-50 text-xl"
                        >CLASSIFICATION</span
                    >
                </div>
                <div
                    class="absolute inset-0 border-2 border-solid border-tertiary-fixed m-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center shadow-[inset_0_0_20px_rgba(168,249,40,0.2)]"
                >
                    <span
                        class="font-label-mono text-tertiary-fixed font-bold flex flex-col items-center gap-2"
                    >
                        <span
                            class="material-symbols-outlined"
                            data-icon="polyline">polyline</span
                        >
                        OPTIMIZATION_MODEL
                    </span>
                </div>
            </div>
            <div class="p-6 border-t border-outline-variant">
                <h4 class="font-headline-md text-[24px] text-on-surface mb-2">
                    Optimizing Classification
                </h4>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Mengoptimasi model klasifikasi pada model DeepMelaNet untuk
                    memprediksi kanker kulit
                </p>
            </div>
        </a>
        <!-- Card 2 -->
        <a
            href="https://github.com/akbarikhsani-26/SIM-Puspaga-Project-Prototype-"
            target="_blank"
            rel="noopener noreferrer"
            class="group block relative bg-surface-container-low border border-outline-variant overflow-hidden hover:no-underline"
        >
            <div
                class="h-48 relative overflow-hidden bg-surface-container-highest"
            >
                <img
                    src="/media/project-2.png"
                    alt="Supply Chain Forecasting"
                    class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-80 transition-all duration-700 group-hover:scale-110"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"
                >
                </div>
                <div
                    class="absolute inset-0 border-2 border-dashed border-error-container m-4 group-hover:opacity-0 transition-opacity duration-500 flex items-center justify-center"
                >
                    <span
                        class="font-label-mono text-error font-bold -rotate-6 opacity-50 text-xl"
                        >PROTOTYPE</span
                    >
                </div>
                <div
                    class="absolute inset-0 border-2 border-solid border-tertiary-fixed m-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center shadow-[inset_0_0_20px_rgba(168,249,40,0.2)]"
                >
                    <span
                        class="font-label-mono text-tertiary-fixed font-bold flex flex-col items-center gap-2"
                    >
                        <span
                            class="material-symbols-outlined"
                            data-icon="model_training">model_training</span
                        >
                        PROTOTYPE_DESIGN
                    </span>
                </div>
            </div>
            <div class="p-6 border-t border-outline-variant">
                <h4 class="font-headline-md text-[24px] text-on-surface mb-2">
                    Website Prototype
                </h4>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Sistem Informasi Manajemen PUSPAGA (Pusat Pembelajaran
                    Keluarga)
                </p>
            </div>
        </a>
        <!-- Card 3 -->
        <a
            href="#"
            class="group block relative bg-surface-container-low border border-outline-variant overflow-hidden hover:no-underline"
        >
            <div
                class="h-48 relative overflow-hidden bg-surface-container-highest"
            >
                <img
                    src="/media/project-3.png"
                    alt="Cloud Infrastructure Scaling"
                    class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-80 transition-all duration-700 group-hover:scale-110"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-surface-container-low to-transparent opacity-60"
                >
                </div>
                <div
                    class="absolute inset-0 border-2 border-dashed border-error-container m-4 group-hover:opacity-0 transition-opacity duration-500 flex items-center justify-center"
                >
                    <span
                        class="font-label-mono text-error font-bold rotate-6 opacity-50 text-xl"
                        >WEB_PORTFOLIO</span
                    >
                </div>
                <div
                    class="absolute inset-0 border-2 border-solid border-tertiary-fixed m-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center shadow-[inset_0_0_20px_rgba(168,249,40,0.2)]"
                >
                    <span
                        class="font-label-mono text-tertiary-fixed font-bold flex flex-col items-center gap-2"
                    >
                        <span class="material-symbols-outlined" data-icon="code"
                            >code</span
                        >
                        DIGITAL_IDENTITY
                    </span>
                </div>
            </div>
            <div class="p-6 border-t border-outline-variant">
                <h4 class="font-headline-md text-[24px] text-on-surface mb-2">
                    Portofolio Website
                </h4>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Pembuatan Website Portofolio Pribadi sebagai sarana
                    menampilkan informasi mengenai diri saya, pengalaman, dan
                    proyek yang pernah dikerjakan
                </p>
            </div>
        </a>
    </div>
</section>

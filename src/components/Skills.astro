---

---

<!-- Capabilities Section -->
<section
    class="flex flex-col justify-center py-12 md:py-16 space-y-12"
    id="strategy"
>
    <div class="flex items-center gap-4">
        <div class="h-px w-12 bg-secondary"></div>
        <h2
            class="font-label-mono text-base md:text-lg text-secondary uppercase tracking-[0.2em]"
        >
            Skills Competencies
        </h2>
    </div>
    <div class="grid grid-cols-1 gap-8">
        <!-- Column 1 -->
        <div class="py-4 relative overflow-hidden w-full">
            <!-- Expansive Background Decoration -->
            <div
                class="absolute -right-20 -top-20 opacity-5 transition-opacity"
            >
                <span
                    class="material-symbols-outlined text-[400px] text-primary"
                    data-icon="insights">insights</span
                >
            </div>

            <!-- Immersive Proficiency Chart -->
            <div class="relative w-full px-4 sm:px-gutter">
                <!-- Desktop / Tablet version: SVG Chart -->
                <div
                    class="hidden md:block overflow-x-auto overflow-y-hidden pb-4"
                >
                    <svg
                        class="w-full min-w-[800px] h-auto drop-shadow-[0_0_20px_rgba(79,70,229,0.2)]"
                        viewBox="0 0 1600 750"
                        preserveAspectRatio="xMidYMid meet"
                    >
                        <!-- Grid Lines (Subtle & Expansive) -->
                        <path
                            d="M 500 50 L 500 620 M 500 620 L 1500 620"
                            fill="none"
                            stroke="var(--color-outline-variant)"
                            stroke-dasharray="8 8"
                            stroke-width="2"></path>

                        <!-- Data Path: Python (70%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="105">PYTHON</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1200"
                            y="85">70%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-dasharray="2000"
                            stroke-dashoffset="0"
                            stroke-width="6"
                            x1="500"
                            x2="1200"
                            y1="100"
                            y2="100"></line>
                        <circle
                            class="animate-pulse"
                            cx="1200"
                            cy="100"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Data Path: SQL (50%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="185">SQL</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1000"
                            y="165">50%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"
                            x2="1000"
                            y1="180"
                            y2="180"></line>
                        <circle
                            class="animate-pulse"
                            cx="1000"
                            cy="180"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Data Path: Data Visualization (80%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="265">DATA VISUALIZATION</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1300"
                            y="245">80%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"
                            x2="1300"
                            y1="260"
                            y2="260"></line>
                        <circle
                            class="animate-pulse"
                            cx="1300"
                            cy="260"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Data Path: Machine Learning (75%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="345">MACHINE LEARNING</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1250"
                            y="325">75%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"
                            x2="1250"
                            y1="340"
                            y2="340"></line>
                        <circle
                            class="animate-pulse"
                            cx="1250"
                            cy="340"
                            fill="var(--color-primary)"
                            r="8"></circle>


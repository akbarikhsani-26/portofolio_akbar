                        </div>
                    </div>

                    <!-- Canva (85%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface">CANVA</span>
                            <span class="text-primary font-bold">85%</span>
                        </div>
                        <div
                            class="w-full h-3 bg-surface-container-high border border-outline-variant rounded-full overflow-hidden"
                        >
                            <div
                                class="h-full bg-primary rounded-full"
                                style="width: 85%"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Excel (85%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface">EXCEL</span>
                            <span class="text-primary font-bold">85%</span>
                        </div>
                        <div
                            class="w-full h-3 bg-surface-container-high border border-outline-variant rounded-full overflow-hidden"
                        >
                            <div
                                class="h-full bg-primary rounded-full"
                                style="width: 85%"
                            >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Column 2 -->
    </div>
</section>

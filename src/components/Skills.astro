                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1200"
                            y="405">70%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"
                            x2="1200"
                            y1="420"
                            y2="420"></line>
                        <circle
                            class="animate-pulse"
                            cx="1200"
                            cy="420"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Data Path: Canva (85%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="505">CANVA</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1350"
                            y="485">85%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"

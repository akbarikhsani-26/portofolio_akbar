                            y1="500"
                            y2="500"></line>
                        <circle
                            class="animate-pulse"
                            cx="1350"
                            cy="500"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Data Path: Excel (85%) -->
                        <text
                            class="italic font-bold"
                            fill="var(--color-on-surface-variant)"
                            font-family="Space Grotesk"
                            font-size="20"
                            text-anchor="end"
                            x="480"
                            y="585">EXCEL</text
                        >
                        <text
                            class="font-label-mono tracking-widest"
                            fill="var(--color-primary)"
                            font-family="Inter"
                            font-size="16"
                            font-weight="600"
                            text-anchor="middle"
                            x="1350"
                            y="565">85%</text
                        >
                        <line
                            stroke="var(--color-primary)"
                            stroke-width="6"
                            x1="500"
                            x2="1350"
                            y1="580"
                            y2="580"></line>
                        <circle
                            class="animate-pulse"
                            cx="1350"
                            cy="580"
                            fill="var(--color-primary)"
                            r="8"></circle>

                        <!-- Percentage Markers -->
                        <text
                            fill="var(--color-outline-variant)"
                            font-size="16"
                            x="500"
                            y="660">0%</text
                        >
                        <text
                            fill="var(--color-outline-variant)"
                            font-size="16"
                            x="1000"
                            y="660">50%</text
                        >
                        <text
                            fill="var(--color-outline-variant)"
                            font-size="16"
                            x="1500"
                            y="660">100%</text
                        >
                    </svg>
                </div>

                <!-- Mobile version: Custom CSS Progress Bars -->
                <div class="block md:hidden space-y-6 px-2">
                    <!-- Python (70%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface">PYTHON</span
                            >
                            <span class="text-primary font-bold">70%</span>
                        </div>
                        <div
                            class="w-full h-3 bg-surface-container-high border border-outline-variant rounded-full overflow-hidden"
                        >
                            <div
                                class="h-full bg-primary rounded-full"
                                style="width: 70%"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- SQL (50%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface">SQL</span>
                            <span class="text-primary font-bold">50%</span>
                        </div>
                        <div
                            class="w-full h-3 bg-surface-container-high border border-outline-variant rounded-full overflow-hidden"
                        >
                            <div
                                class="h-full bg-primary rounded-full"
                                style="width: 50%"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Data Visualization (80%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface"
                                >DATA VISUALIZATION</span
                            >
                            <span class="text-primary font-bold">80%</span>
                        </div>
                        <div
                            class="w-full h-3 bg-surface-container-high border border-outline-variant rounded-full overflow-hidden"
                        >
                            <div
                                class="h-full bg-primary rounded-full"
                                style="width: 80%"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Machine Learning (75%) -->
                    <div class="space-y-2">
                        <div
                            class="flex justify-between items-center text-sm font-label-mono"
                        >
                            <span class="font-bold text-on-surface"
                                >MACHINE LEARNING</span
                            >
                            <span class="text-primary font-bold">75%</span>
                        </div>
                        <div

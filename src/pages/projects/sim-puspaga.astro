---
import Layout from "../../layouts/main.astro";
---

<Layout title="SIM-Puspaga - Project Documentation">
    <style>
        .paper-shadow {
            box-shadow:
                0 10px 30px rgba(79, 70, 229, 0.05),
                0 0 0 1px rgba(79, 70, 229, 0.1);
        }

        .tape-left {
            position: absolute;
            top: -15px;
            left: 20px;
            width: 80px;
            height: 30px;
            background-color: rgba(6, 182, 212, 0.3); /* Secondary color */
            transform: rotate(-3deg);
            z-index: 10;
        }

        .tape-right {
            position: absolute;
            top: -15px;
            right: 20px;
            width: 80px;
            height: 30px;
            background-color: rgba(6, 182, 212, 0.3);
            transform: rotate(2deg);
            z-index: 10;
        }

        .tape-center {
            position: absolute;
            top: -12px;
            left: 50%;
            width: 80px;
            height: 30px;
            background-color: rgba(79, 70, 229, 0.3);
            transform: translateX(-50%) rotate(-2deg);
            z-index: 10;
        }

        .blueprint-grid {
            background-size: 40px 40px;
            background-image:
                linear-gradient(
                    to right,
                    rgba(0, 0, 0, 0.03) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    to bottom,
                    rgba(0, 0, 0, 0.03) 1px,
                    transparent 1px
                );
        }
    </style>

    <div
        class="blueprint-grid min-h-screen relative py-20 px-4 md:px-12 flex justify-center items-start mt-10"
    >
        <!-- Floating Back to Portfolio Button -->
        <div class="fixed top-4 left-4 md:top-8 md:left-8 z-50">
            <a href="/#experience" class="relative inline-block group">
                <span
                    class="absolute inset-0 w-full h-full bg-primary/20 border border-primary/30 rounded-sm translate-x-1 translate-y-1 transition-transform group-hover:translate-x-0 group-hover:translate-y-0"
                ></span>
                <span
                    class="relative flex items-center gap-2 px-4 py-2 bg-surface/80 backdrop-blur-md border border-outline-variant text-primary font-label-mono text-xs uppercase tracking-wider rounded-sm transition-transform group-hover:translate-x-1 group-hover:translate-y-1 active:translate-x-0.5 active:translate-y-0.5"
                >
                    <span class="material-symbols-outlined text-[16px]"
                        >arrow_back</span
                    >
                    Back to Portfolio
                </span>
            </a>
        </div>

        <!-- The Paper -->
        <main
            class="w-full max-w-[1000px] bg-surface-container-low paper-shadow rounded-sm relative transition-all duration-500 ease-in-out transform md:rotate-[0.5deg] hover:rotate-0 hover:-translate-y-1"
        >
            <!-- Tape Accents -->
            <div class="tape-left hidden md:block"></div>
            <div class="tape-right hidden md:block"></div>

            <!-- Header Section -->
            <header class="border-b border-outline-variant p-8 md:p-12">
                <div
                    class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4"
                >
                    <div>
                        <h1
                            class="font-headline-lg text-4xl md:text-5xl text-primary mb-4 font-bold tracking-tight"
                        >
                            IT Intern at Puspaga Division
                        </h1>
                        <p
                            class="font-body-md text-lg text-on-surface-variant flex items-center gap-2"
                        >
                            <span
                                class="material-symbols-outlined text-outline"
                                style="font-variation-settings: 'FILL' 0;"
                                >family_restroom</span
                            >
                            Dinas Pemberdayaan Perempuan, Perlindungan Anak, Pengendalian
                            Penduduk, dan Keluarga Berencana Kota Batu
                        </p>
                        <p
                            class="font-body-md text-lg text-on-surface-variant flex items-center gap-2"
                        >
                            <span
                                class="material-symbols-outlined text-outline"
                                style="font-variation-settings: 'FILL' 0;"
                                >calendar_today</span
                            >
                            August 2024 - September 2024
                        </p>
                    </div>
                </div>
            </header>

            <!-- Content Area -->
            <div class="p-8 md:p-12 space-y-16">
                <!-- Section 1: Overview -->
                <section>
                    <div
                        class="flex items-center gap-4 mb-6 border-b border-outline-variant pb-2"
                    >
                        <span
                            class="material-symbols-outlined text-primary"
                            style="font-variation-settings: 'FILL' 1;"
                            >overview</span
                        >
                        <h2 class="font-headline-md text-2xl text-primary">
                            Overview
                        </h2>
                    </div>
                    <p
                        class="font-body-lg text-on-surface-variant mb-10 max-w-3xl leading-relaxed text-justify"
                    >
                        Mempelajari sistem administrasi dan membantu terhadap
                        pelayanan administrasi sehingga tercapainya standarisasi
                        Divisi Puspaga, disertai dengan Pembuatan prototype
                        sistem informasi manajemen pelayanan Puspaga dirancang
                        untuk mengoptimalkan Layanan Konseling & Edukasi
                        Keluarga. Sistem ini menyediakan platform terpadu untuk
                        pencatatan kasus, penjadwalan sesi konseling, dan
                        pelaporan yang efisien.
                    </p>
                    <div class="mt-8">
                        <h3 class="font-headline-md text-xl text-primary mb-3">
                            Project Detail
                        </h3>
                        <p
                            class="font-body-md text-on-surface-variant text-justify max-w-3xl leading-relaxed"
                        >
                            Project ini diperuntukan untuk membantu dalam
                            pencatatan dan pelayanan terhadap klien serta
                            manajemen divisi puspaga. Dengan sistem ini,
                            diharapkan dapat membantu dalam proses pelayanan
                            terhadap klien dan mempermudah dalam pencatatan data
                            secara digital dan terstruktur.
                        </p>
                    </div>
                </section>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Feature Card 1 -->
                    <div
                        class="border border-outline-variant p-6 bg-surface transition-colors hover:bg-surface-variant group"
                    >
                        <div class="flex items-center gap-2 mb-4">
                            <span
                                class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors"
                                style="font-variation-settings: 'FILL' 0;"
                                >database</span
                            >
                            <h3 class="font-headline-md text-lg text-primary">
                                Manajemen Data
                            </h3>
                        </div>
                        <p
                            class="font-body-md text-sm text-on-surface-variant text-justify"
                        >
                            Pencatatan rekam jejak konseli secara aman dan
                            terstruktur dengan sistem enkripsi standar.
                        </p>
                    </div>

                    <!-- Feature Card 2 -->
                    <div
                        class="border border-outline-variant p-6 bg-surface transition-colors hover:bg-surface-variant group"
                    >
                        <div class="flex items-center gap-2 mb-4">
                            <span
                                class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors"
                                style="font-variation-settings: 'FILL' 0;"
                                >calendar_month</span
                            >
                            <h3 class="font-headline-md text-lg text-primary">
                                Penjadwalan
                            </h3>
                        </div>
                        <p
                            class="font-body-md text-sm text-on-surface-variant text-justify"
                        >
                            Sistem kalender terintegrasi untuk mengatur sesi
                            konseling antara konselor dan klien tanpa bentrok
                            jadwal.
                        </p>
                    </div>

                    <!-- Feature Card 3 -->
                    <div
                        class="border border-outline-variant p-6 bg-surface transition-colors hover:bg-surface-variant group"
                    >
                        <div class="flex items-center gap-2 mb-4">
                            <span
                                class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors"
                                style="font-variation-settings: 'FILL' 0;"
                                >monitoring</span
                            >
                            <h3 class="font-headline-md text-lg text-primary">
                                Laporan Real-time
                            </h3>
                        </div>
                        <p
                            class="font-body-md text-sm text-on-surface-variant text-justify"
                        >
                            Dashboard analitik untuk memantau tren kasus dan
                            menghasilkan laporan kinerja layanan secara instan.
                        </p>
                    </div>
                </div>

                <!-- Section 2: Photo Documentation -->
                <section>
                    <div
                        class="flex items-center gap-4 mb-6 border-b border-outline-variant pb-2"
                    >
                        <span
                            class="material-symbols-outlined text-primary"
                            style="font-variation-settings: 'FILL' 1;"
                            >photo_library</span
                        >
                        <h2 class="font-headline-md text-2xl text-primary">
                            Photo Documentation
                        </h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 py-6">
                        <!-- Photo 1 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div class="tape-center"></div>
                            <img
                                src="/media/project-2.png"
                                alt="SIM-Puspaga Preview 1"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 1. HALAMAN LANDING PAGE
                            </p>
                        </div>

                        <!-- Photo 2 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[1.5deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-4.png"
                                alt="SIM-Puspaga Preview 2"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 2. HALAMAN DASHBOARD
                            </p>
                        </div>

                        <!-- Photo 3 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform rotate-[1.5deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div class="tape-center"></div>
                            <img
                                src="/media/Puspaga-5.png"
                                alt="SIM-Puspaga Preview 1"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 3. HALAMAN MANAJEMEN KARYAWAN
                            </p>
                        </div>

                        <!-- Photo 4 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-6.png"
                                alt="SIM-Puspaga Preview 2"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 4. HALAMAN MANAJEMEN KASUS DAN PENJADWALAN
                                KARYAWAN
                            </p>
                        </div>

                        <!-- Photo 5 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform rotate-[1.5deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div class="tape-center"></div>
                            <img
                                src="/media/Puspaga-7.png"
                                alt="SIM-Puspaga Preview 1"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 5. HALAMAN FORMULIR PELAPORAN
                            </p>
                        </div>

                        <!-- Photo 6 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-8.png"
                                alt="SIM-Puspaga Preview 2"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 6. HALAMAN PROFILE PENGGUNA
                            </p>
                        </div>

                        <!-- Photo 7 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform rotate-[1.5deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div class="tape-center"></div>
                            <img
                                src="/media/Puspaga-9.png"
                                alt="SIM-Puspaga Preview 1"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 7. HALAMAN PROGRESS LAPORAN
                            </p>
                        </div>

                        <!-- Photo 8 -->
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-2.jpeg"
                                alt="SIM-Puspaga Preview 2"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 8. MEMBANTU DALAM ADMINISTRASI
                            </p>
                        </div>
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-10.jpeg"
                                alt="SIM-Puspaga Preview 1"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 9. MEMBANTU DALAM PELAYANAN PUSPAGA
                            </p>
                        </div>
                        <div
                            class="bg-surface p-3 pb-10 border border-outline-variant shadow-xl relative w-full transform -rotate-[2deg] hover:rotate-0 transition-transform duration-300"
                        >
                            <div
                                class="tape-center"
                                style="transform: translateX(-50%) rotate(3deg); background-color: rgba(6, 182, 212, 0.3);"
                            >
                            </div>
                            <img
                                src="/media/Puspaga-3.jpeg"
                                alt="SIM-Puspaga Preview 2"
                                class="w-full h-auto border border-outline-variant/30 grayscale hover:grayscale-0 transition-all duration-500 object-cover"
                            />
                            <p
                                class="font-label-mono text-center text-xs text-on-surface-variant mt-4 font-bold tracking-widest"
                            >
                                FIG 10. PERTEMUAN DENGAN INTERNAL PUSPAGA
                            </p>
                        </div>
                    </div>
                </section>

                <!-- Section 3: Tech Stack -->
                <section>
                    <div
                        class="flex items-center gap-4 mb-6 border-b border-outline-variant pb-2"
                    >
                        <span
                            class="material-symbols-outlined text-primary"
                            style="font-variation-settings: 'FILL' 1;"
                            >terminal</span
                        >
                        <h2 class="font-headline-md text-2xl text-primary">
                            Tech Stack
                        </h2>
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <!-- Chip 1 -->
                        <div
                            class="flex items-center gap-2 border border-outline-variant px-4 py-2 bg-surface font-label-mono text-xs text-primary relative -rotate-[0.5deg] hover:rotate-0 transition-transform"
                        >
                            <span class="material-symbols-outlined text-[18px]"
                                >rocket_launch</span
                            >
                            Astro
                        </div>
                        <!-- Chip 2 -->
                        <div
                            class="flex items-center gap-2 border border-outline-variant px-4 py-2 bg-surface font-label-mono text-xs text-primary relative rotate-[0.5deg] hover:rotate-0 transition-transform"
                        >
                            <span class="material-symbols-outlined text-[18px]"
                                >palette</span
                            >
                            Tailwind CSS
                        </div>
                        <!-- Chip 3 -->
                        <div
                            class="flex items-center gap-2 border border-outline-variant px-4 py-2 bg-surface font-label-mono text-xs text-primary relative -rotate-[1deg] hover:rotate-0 transition-transform"
                        >
                            <span class="material-symbols-outlined text-[18px]"
                                >dns</span
                            >
                            Node.js
                        </div>
                        <!-- Chip 4 -->
                        <div
                            class="flex items-center gap-2 border border-outline-variant px-4 py-2 bg-surface font-label-mono text-xs text-primary relative rotate-[1deg] hover:rotate-0 transition-transform"
                        >
                            <span class="material-symbols-outlined text-[18px]"
                                >storage</span
                            >
                            MySQL
                        </div>
                    </div>
                </section>

                <!-- Section 4: Installation -->
                <section>
                    <div
                        class="flex items-center gap-4 mb-6 border-b border-outline-variant pb-2"
                    >
                        <span
                            class="material-symbols-outlined text-primary"
                            style="font-variation-settings: 'FILL' 1;"
                            >build</span
                        >
                        <h2 class="font-headline-md text-2xl text-primary">
                            Source Code
                        </h2>
                    </div>
                    <p
                        class="font-body-md text-on-surface-variant mb-6 text-justify"
                    >
                        Berikut adalah tautan repositori GitHub yang berisi
                        seluruh kode sumber untuk proyek SIM-Puspaga.
                    </p>
                    <a
                        href="https://github.com/akbarikhsani-26/SIM-Puspaga-Project-Prototype-"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex flex-col md:flex-row items-start md:items-center justify-between gap-4 border border-outline-variant p-6 bg-surface transition-colors hover:bg-surface-variant hover:no-underline rounded-sm max-w-2xl"
                    >
                        <div class="flex items-center gap-4">
                            <div
                                class="p-3 bg-primary-container text-on-primary-container rounded-sm group-hover:bg-primary group-hover:text-on-primary transition-colors flex items-center justify-center"
                            >
                                <svg
                                    class="w-6 h-6 fill-current"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        clip-rule="evenodd"
                                        d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3
                                    class="font-headline-md text-lg text-primary font-bold flex items-center gap-2"
                                >
                                    SIM-Puspaga-Project-Prototype-
                                </h3>
                                <p
                                    class="font-body-md text-sm text-on-surface-variant mt-1"
                                >
                                    Lihat repositori GitHub untuk kode sumber
                                    lengkap, dokumentasi, dan pengembangan
                                    sistem.
                                </p>
                            </div>
                        </div>
                        <span
                            class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-all group-hover:translate-x-1"
                        >
                            arrow_forward
                        </span>
                    </a>
                </section>
            </div>

            <!-- Footer / Page Numbering -->
            <footer
                class="border-t border-outline-variant p-4 flex justify-between items-center bg-surface font-label-mono text-xs text-on-surface-variant"
            >
                <span>Doc Ref: SP-01A</span>

                <a
                    href="/#experience"
                    class="hover:text-primary transition-colors flex items-center gap-1"
                >
                    <span class="material-symbols-outlined text-[14px]"
                        >arrow_back</span
                    >
                    Back to Portfolio
                </a>

                <span>Page 1 of 1</span>
            </footer>
        </main>
    </div>
</Layout>
